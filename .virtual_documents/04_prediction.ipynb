# loading the dataset 
import pandas as pd 
import numpy as np
df=pd.read_csv("cleaned_csv")


df.drop("Unnamed: 0",axis=1,inplace=True)


df.head()


#loading the model
import joblib

model = joblib.load("model.pkl")
preprocessor=joblib.load("preprocessor.pkl")


model


preprocessor





df.iloc[89000]


def prediction(gender,age,hypertension,heart_disease,smoking_history,bmi,HbA1c_level,blood_glucose_level):
    features=np.array([[gender,age,hypertension,heart_disease,smoking_history,bmi,HbA1c_level,blood_glucose_level]])
    transformed_feature=preprocessor.transform(features)
    prediction=model.predict(transformed_feature).reshape(1,-1)
    return prediction[0]


gender="Female"
age=45
